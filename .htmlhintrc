{
  "doctype-first": true,
  "doctype-html5": true,
  "title-require": true,
  "attr-lowercase": true,
  "attr-value-double-quotes": true,
  "attr-no-duplication": true,
  "tag-pair": true,
  "spec-char-escape": true,
  "id-unique": true,
  "src-not-empty": true,
  "alt-require": true,
  "inline-style-disallow": false,
  "inline-script-disallow": false
}
